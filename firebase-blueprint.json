{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a library portal user (Student, Faculty, Librarian, Administrator).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "user_name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Student", "Faculty", "Librarian", "Administrator"] },
        "dept": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Suspended", "Inactive"] },
        "joined": { "type": "string" },
        "profile": { "type": "map" },
        "preferences": { "type": "map" }
      },
      "required": ["userId", "email", "role", "status"]
    },
    "Book": {
      "title": "Book",
      "description": "A book in the catalog",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "isbn": { "type": "string" },
        "category": { "type": "string" },
        "year": { "type": "number" },
        "totalCopies": { "type": "number" },
        "availCopies": { "type": "number" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "archived": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "addedBy": { "type": "string" }
      },
      "required": ["title", "author", "isbn", "totalCopies", "availCopies"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A loan transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "bookId": { "type": "string" },
        "bookTitle": { "type": "string" },
        "checkout": { "type": "string" },
        "due": { "type": "string" },
        "returned": { "type": "string" },
        "status": { "type": "string", "enum": ["Borrowed", "Returned", "Lost"] },
        "fine": { "type": "number" },
        "fineStatus": { "type": "string" },
        "processedBy": { "type": "string" },
        "renewalCount": { "type": "number" }
      },
      "required": ["userId", "bookId", "checkout", "due", "status", "fineStatus"]
    },
    "FacultyReserve": {
      "title": "FacultyReserve",
      "description": "Course reserve requested by faculty",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "dept": { "type": "string" },
        "courseName": { "type": "string" },
        "semester": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Published"] },
        "items": { "type": "list" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "dept", "status"]
    },
    "StudentReservation": {
      "title": "StudentReservation",
      "description": "Pickup or waitlist request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "bookId": { "type": "string" },
        "bookTitle": { "type": "string" },
        "type": { "type": "string", "enum": ["Pickup", "Waitlist"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "bookId", "type", "status"]
    },
    "ProcurementRequest": {
        "title": "Procurement",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "title": { "type": "string" },
            "status": { "type": "string" }
        }
    },
    "SystemConfig": {
        "title": "SystemConfig",
        "type": "object",
        "properties": {
            "loanPeriodDays": { "type": "number" },
            "fineRate": { "type": "number" },
            "renewalLimit": { "type": "number" }
        }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of all members"
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of all books"
    },
    "/transactions/{transactionId}": {
        "schema": "Transaction",
        "description": "Loan records"
    },
    "/facultyReserves/{reserveId}": {
        "schema": "FacultyReserve",
        "description": "Reserves managed by Faculty"
    },
    "/studentReservations/{reservationId}": {
        "schema": "StudentReservation",
        "description": "Book pickup and waitlist requests"
    },
    "/procurements/{procurementId}": {
        "schema": "ProcurementRequest",
        "description": "Faculty procurement requests"
    },
    "/system/config": {
        "schema": "SystemConfig",
        "description": "Global config singleton"
    }
  }
}
