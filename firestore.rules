rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} { 
      allow read, write: if false; 
    }

    // ===============================================================
    // Primitives
    // ===============================================================
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // Bootstrapped Admin
    function isBootstrappedAdmin() {
      return request.auth != null && request.auth.token.email == 'jaybalajijanakiraman@gmail.com';
    }
    
    // Auth Token vs DB Role lookup
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { 
      return isBootstrappedAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Administrator'); 
    }
    function isLibrarian() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Librarian'; 
    }
    function isFaculty() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Faculty'; 
    }
    function isStudent() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Student'; 
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================
    function isValidUser(data) {
      return data.userId is string && data.userId.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['Administrator', 'Librarian', 'Faculty', 'Student'] &&
             data.status in ['Active', 'Suspended', 'Inactive'] &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             data.user_name is string && data.user_name.size() <= 200 &&
             data.joined is string && data.joined.size() <= 30;
    }

    function isValidBook(data) {
      return data.title is string && data.title.size() <= 500 &&
             data.author is string && data.author.size() <= 200 &&
             data.isbn is string && data.isbn.size() <= 50 &&
             data.totalCopies is number && data.totalCopies >= 0 &&
             data.availCopies is number && data.availCopies >= 0 && data.availCopies <= data.totalCopies &&
             data.status is string && data.status.size() <= 50 &&
             data.category is string && data.category.size() <= 100 &&
             data.archived is bool;
    }

    function isValidTransaction(data) {
      return data.userId is string && data.userId.size() <= 100 &&
             data.bookId is string && data.bookId.size() <= 128 &&
             data.checkout is string && data.checkout.size() <= 30 &&
             data.due is string && data.due.size() <= 30 &&
             data.status in ['Borrowed', 'Returned', 'Lost'] &&
             data.fineStatus is string && data.fineStatus.size() <= 50 &&
             data.fine is number && data.fine >= 0 &&
             data.renewalCount is number && data.renewalCount >= 0;
    }

    function isValidFacultyReserve(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.dept is string && data.dept.size() <= 100 &&
             data.status in ['Draft', 'Published'] &&
             data.items is list && data.items.size() <= 100;
    }

    function isValidStudentReservation(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.bookId is string && data.bookId.size() <= 128 &&
             data.type in ['Pickup', 'Waitlist'] &&
             data.status is string && data.status.size() <= 100;
    }

    function isValidSystemConfig(data) {
      return data.loanPeriodDays is number && data.loanPeriodDays >= 0 &&
             data.fineRate is number && data.fineRate >= 0 &&
             data.renewalLimit is number && data.renewalLimit >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAdmin() || isLibrarian() || isFaculty() || (isSignedIn() && request.auth.uid == uid);
      allow create: if (isAdmin() || (isSignedIn() && request.auth.uid == uid)) && 
                       incoming().keys().hasAny(['userId', 'email', 'role', 'status']) && isValidUser(incoming());
      allow update: if (isAdmin() && isValidUser(incoming())) ||
                       (isSignedIn() && request.auth.uid == uid && incoming().diff(existing()).affectedKeys().hasOnly(['profile', 'preferences']));
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isLibrarian()) && isValidBook(incoming());
      allow update: if (isAdmin() || isLibrarian()) && isValidBook(incoming());
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || isLibrarian() || isFaculty() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if (isAdmin() || isLibrarian()) && 
                       exists(/databases/$(database)/documents/books/$(incoming().bookId)) &&
                       isValidTransaction(incoming());
      allow update: if (isAdmin() || isLibrarian()) && isValidTransaction(incoming());
      allow delete: if false; // Transactions represent financial state. Admin logs required.
    }

    match /facultyReserves/{reserveId} {
      allow read: if isAdmin() || isLibrarian() || (isFaculty() && existing().userId == request.auth.uid) || isStudent();
      allow create: if isFaculty() && isValidFacultyReserve(incoming());
      allow update: if (isFaculty() && existing().userId == request.auth.uid && isValidFacultyReserve(incoming()) && incoming().userId == existing().userId) ||
                       (isAdmin() || isLibrarian());
      allow delete: if isAdmin() || (isFaculty() && existing().userId == request.auth.uid);
    }

    match /studentReservations/{reservationId} {
      allow read: if isAdmin() || isLibrarian() || (isStudent() && existing().userId == request.auth.uid);
      allow create: if isStudent() && isValidStudentReservation(incoming()) && exists(/databases/$(database)/documents/books/$(incoming().bookId));
      allow update: if isAdmin() || isLibrarian(); // Students cannot modify queue
      allow delete: if isAdmin() || isLibrarian() || (isStudent() && existing().userId == request.auth.uid);
    }

    match /system/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(); // Needed for restore functionality
    }
    
    // Additional collections for Faculty/Admin
    match /reserves/{docId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn();
      allow create, update: if isFaculty() || isLibrarian();
    }

    match /procurements/{docId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn();
      allow create, update: if isFaculty() || isLibrarian();
    }

    match /bulkRequests/{docId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn();
      allow create, update: if isFaculty() || isLibrarian();
    }
  }
}
